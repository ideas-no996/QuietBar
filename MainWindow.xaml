<Window x:Class="QuietBar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QuietBar"
        Width="164"
        Height="34"
        MinWidth="164"
        MinHeight="34"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave">
  <Window.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
      <Setter Property="Effect">
        <Setter.Value>
          <DropShadowEffect BlurRadius="3"
                            ShadowDepth="1"
                            Direction="270"
                            Opacity="0.55"
                            Color="#000000" />
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>
  <Border x:Name="RootChrome"
          CornerRadius="8"
          Padding="10,6"
          Background="#CC111418"
          BorderBrush="#33FFFFFF"
          BorderThickness="1"
          SnapsToDevicePixels="True">
    <Border.Effect>
      <DropShadowEffect BlurRadius="14"
                        ShadowDepth="0"
                        Opacity="0.28"
                        Color="#000000" />
    </Border.Effect>
    <StackPanel Orientation="Vertical">
      <StackPanel Orientation="Horizontal">
        <TextBlock x:Name="CollapsedCpuText"
                   Foreground="#F3F7FA"
                   FontWeight="SemiBold" />
        <TextBlock Text="  "
                   Foreground="#F3F7FA" />
        <TextBlock x:Name="CollapsedGpuText"
                   Foreground="#F3F7FA"
                   FontWeight="SemiBold" />
      </StackPanel>
      <StackPanel x:Name="ExpandedPanel"
                  Margin="0,5,0,0"
                  Visibility="Collapsed">
        <TextBlock x:Name="RamText"
                   Foreground="#F3F7FA" />
        <TextBlock x:Name="VramText"
                   Foreground="#F3F7FA" />
        <TextBlock x:Name="TemperatureText"
                   Foreground="#F3F7FA" />
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
